# PHANTOM-3B Environment Variables
# Copy this file to .env and fill in your values

# --- Perplexica (optional local AI search) ---
PERPLEXICA_API_URL=http://localhost:3000/api/search
PERPLEXICA_API_KEY=

# --- HuggingFace Token (for faster model downloads) ---
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# --- App Config ---
STREAMLIT_PORT=8501
DEBUG_MODE=False
